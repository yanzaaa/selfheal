# ── LLM provider ───────────────────────────────────────────────
# mock = no key needed (full self-heal loop). anthropic | openai for live AI.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── UiPath Test Cloud (external application, client-credentials) ──
UIPATH_BASE_URL=https://cloud.uipath.com
UIPATH_ACCOUNT=your-org-logical-name      # e.g. yanza
UIPATH_TENANT=DefaultTenant
UIPATH_PROJECT=YAN                        # Test Manager project key
UIPATH_CLIENT_ID=                         # App ID from External Applications
UIPATH_CLIENT_SECRET=                     # App Secret (shown once)
UIPATH_SCOPE=OR.Execution TM.Projects     # space-separated APPLICATION scopes you granted
UIPATH_REPORT=0                           # set 1 to push results into Test Manager
