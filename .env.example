# LLM provider: mock | anthropic | openai
# "mock" runs the full self-heal loop with NO API key (great for the demo).
LLM_PROVIDER=mock

# If LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# If LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# UiPath (fill once your Automation Cloud + Test Cloud account is live)
UIPATH_ORCH_URL=
UIPATH_TENANT=
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=
